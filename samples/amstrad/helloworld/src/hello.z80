    DEVICE AMSTRADCPC6128

    ORG 0x4000

PRINT_CHAR EQU 0xBB5A
WAIT_CHAR EQU 0xBB06

MAIN:
    LD A,#0
    CALL 0xBC0E

    LD A,'H'
    CALL PRINT_CHAR
    LD A,'E'
    CALL PRINT_CHAR
    LD A,'L'
    CALL PRINT_CHAR
    LD A,'L'
    CALL PRINT_CHAR
    LD A,'O'
    CALL PRINT_CHAR

    LD HL,0xC370
    LD C,10d
PIXEL_LOOP:
    LD (HL),255
    INC HL

    DEC C
    JP NZ,PIXEL_LOOP

    LD HL,0xCB70
    LD (HL),255

    CALL WAIT_CHAR

    RET

    SAVEBIN "build/hello.bin",0x4000,0x1000
